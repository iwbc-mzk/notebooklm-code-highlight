{
  "manifest_version": 3,
  "name": "NotebookLM Code Highlight",
  "version": "1.0.0",
  "description": "Adds syntax highlighting to code blocks in Google NotebookLM",
  "permissions": ["storage"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["fonts/*"],
      "matches": ["https://notebooklm.google.com/*"]
    }
  ],
  "content_scripts": [
    {
      "matches": ["https://notebooklm.google.com/*"],
      "js": ["lib/highlight.min.js", "lib/mermaid.min.js", "content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}
